# Copy this file to `.env` and fill in your values. Do not commit `.env`.

# --- Firebase / Firestore (required) ---
# Download a service account JSON from GCP: IAM → Service accounts → Keys
# Use an absolute path so the app finds the file no matter where you run it from.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-service-account.json

# --- Gemini: pick ONE path ---

# Path A — Gemini Developer API (AI Studio API key). Free tier is very small for multi-step agents.
# GOOGLE_API_KEY=your-api-key-from-aistudio

# Path B — Vertex AI (uses GCP billing / hackathon credits). Enable Vertex AI API on the same project.
# When using Vertex, leave GOOGLE_API_KEY unset so the SDK uses service-account auth.
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Agent tuning ---
# Model id passed to ADK (must exist on your chosen backend: Developer API or Vertex).
ADK_MODEL=gemini-2.5-flash

# 1 = leaner user prompt (fewer redundant tool calls). Sub-agents stay attached; Scrum/Notion still required for project work with deadlines.
# 0 = fuller coordination wording in the prompt.
ADK_LITE=1

# --- Member 2: Notion + Google Calendar ---
# NOTION_TOKEN=
# NOTION_DATABASE_ID=
# Optional: hub page id ("Runs") — each POST creates a child page; tasks append as to-dos on that page.
# Required: open that page in Notion → Share → invite your integration (e.g. autonomous-rnd-agent).
# If unset, tools use NOTION_DATABASE_ID only.
# NOTION_RUNS_PARENT_PAGE_ID=
# Set to 1 to create a separate Kanban database on each run page instead of to-do blocks.
# NOTION_RUN_USE_KANBAN_DB=0
# Optional: exact column names on NOTION_DATABASE_ID if auto-detect fails (must match that board).
# Wrong names → "Status is not a property". Remove these if unsure and rely on auto-detect.
# NOTION_PROP_TITLE=
# NOTION_PROP_STATUS=
# NOTION_PROP_DATE=
# If cards still fail (API 2025-09-03): copy data source id from Notion → database → Manage data sources
# NOTION_DATA_SOURCE_ID=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALENDAR_ID=primary
# After setting client id/secret, run: python auth_setup.py  → creates token.json

# --- Research ---
# Web search via `ddgs` (pip install ddgs; no API key). If results are empty, try WEB_SEARCH_BACKEND=bing.
# WEB_SEARCH_MAX_RESULTS=8
# WEB_SEARCH_TIMEOUT=30
# WEB_SEARCH_BACKEND=auto
# arXiv (optional fallback; slower on some networks)
# ARXIV_MAX_RESULTS=5

# --- Workspace prep (on-disk folders under this path) ---
# WORKSPACE_OUTPUT_DIR=generated_workspaces

# --- MCP (Model Context Protocol) over HTTP — same server as FastAPI ---
# Judges/clients connect to: https://<your-host>/mcp/  (local: http://127.0.0.1:8000/mcp/)
# When set (non-empty), require either header on every MCP request:
#   Authorization: Bearer <same value>
#   X-MCP-API-Key: <same value>
# Leave unset or empty for local dev only — MCP is then unauthenticated.
# MCP_AUTH_TOKEN=

# --- CORS (only if UI and API are on different origins) ---
# Comma-separated origins, e.g. https://my-ui.run.app
# CORS_ALLOW_ORIGINS=
# Optional regex, e.g. https://.*\.run\.app — use with care
# CORS_ALLOW_ORIGIN_REGEX=
